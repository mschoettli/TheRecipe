{
  "manifest_version": 3,
  "name": "TheRecipe Saver",
  "description": "Send the current recipe page to TheRecipe.",
  "version": "0.1.0",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["http://localhost:8000/*", "http://127.0.0.1:8000/*"],
  "action": {
    "default_title": "Save to TheRecipe",
    "default_popup": "popup.html"
  }
}
